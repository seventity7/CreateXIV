<Project Sdk="Dalamud.NET.Sdk/14.0.2">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Platforms>x64</Platforms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <AssemblyName>CreateXIV</AssemblyName>
    <RootNamespace>CreateXIV</RootNamespace>

    <!-- Manifest fields (Packager lê daqui) -->
    <Author>Bryer</Author>
    <Name>CreateXIV</Name>
    <Punchline>Create custom macro and plugin command aliases.</Punchline>
    <Description>Create vanilla-like macro aliases (macro/shared) and plugin command aliases via /create.</Description>
    <RepoUrl>https://github.com/seventity7/CreateXIV</RepoUrl>

    <!-- API atual do Dalamud -->
    <DalamudApiLevel>14</DalamudApiLevel>

    <!-- Versão fixa (não timestamp) -->
    <Version>1.0.4</Version>
  </PropertyGroup>
</Project>